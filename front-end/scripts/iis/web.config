<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <!--
    IIS web.config for the Tauri auto-update static file server.
    Place this file in the IIS site root (e.g. C:\inetpub\tyresoles-updates\).
  -->
  <system.webServer>

    <!-- Ensure correct MIME types for update artifacts -->
    <staticContent>
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <remove fileExtension=".sig" />
      <mimeMap fileExtension=".sig" mimeType="application/octet-stream" />
      <remove fileExtension=".exe" />
      <mimeMap fileExtension=".exe" mimeType="application/octet-stream" />
      <remove fileExtension=".msi" />
      <mimeMap fileExtension=".msi" mimeType="application/octet-stream" />
    </staticContent>

    <!-- Add CORS headers so Tauri can fetch from any origin -->
    <httpProtocol>
      <customHeaders>
        <add name="Access-Control-Allow-Origin" value="*" />
        <add name="Access-Control-Allow-Methods" value="GET, HEAD, OPTIONS" />
        <add name="Access-Control-Allow-Headers" value="Content-Type" />
      </customHeaders>
    </httpProtocol>

    <!-- Disable caching for update.json so clients always get the latest -->
    <rewrite>
      <outboundRules>
        <rule name="NoCacheUpdateJson" preCondition="IsUpdateJson">
          <match serverVariable="RESPONSE_Cache-Control" pattern=".*" />
          <action type="Rewrite" value="no-cache, no-store, must-revalidate" />
        </rule>
        <preConditions>
          <preCondition name="IsUpdateJson">
            <add input="{REQUEST_URI}" pattern="update\.json$" />
          </preCondition>
        </preConditions>
      </outboundRules>
    </rewrite>

    <!-- Allow large file downloads (up to 500 MB) -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="524288000" />
      </requestFiltering>
    </security>

  </system.webServer>
</configuration>
