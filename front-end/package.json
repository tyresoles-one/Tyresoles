{
	"name": "front-end",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:force": "vite dev --force",
		"build": "vite build",
		"preview": "vite preview",
		"start": "vite preview",
		"tauri": "tauri",
		"tauri:dev": "tauri dev",
		"tauri:build": "tauri build",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"codegen": "graphql-codegen --config codegen.ts",
		"codegen:dev": "node scripts/codegen-dev.mjs",
		"codegen:dev:ps": "$env:NODE_TLS_REJECT_UNAUTHORIZED=0; npm run codegen",
		"codegen:watch": "graphql-codegen --config codegen.ts --watch",
		"codegen:watch:dev": "node scripts/codegen-dev.mjs --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:install": "playwright install --with-deps chromium"
	},
	"devDependencies": {
		"@capacitor/cli": "^8.3.0",
		"@graphql-codegen/cli": "^5.0.2",
		"@graphql-codegen/client-preset": "^4.2.3",
		"@graphql-codegen/typescript": "^4.1.1",
		"@graphql-codegen/typescript-operations": "^4.2.0",
		"@graphql-typed-document-node/core": "^3.2.0",
		"@internationalized/date": "^3.10.1",
		"@lucide/svelte": "^0.561.0",
		"@playwright/test": "^1.56.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.49.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/vite": "^4.1.17",
		"@tanstack/table-core": "^8.21.3",
		"@tauri-apps/cli": "^2.10.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.2.9",
		"@vitest/coverage-v8": "^3.2.4",
		"bits-ui": "^2.15.4",
		"clsx": "^2.1.1",
		"embla-carousel-svelte": "^8.6.0",
		"jsdom": "^27.2.0",
		"layerchart": "^2.0.0-next.43",
		"mode-watcher": "^1.1.0",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.45.6",
		"svelte-check": "^4.3.4",
		"svelte-sonner": "^1.0.7",
		"svelte2tsx": "^0.7.51",
		"tailwind-merge": "^3.4.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.17",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vaul-svelte": "^1.0.0-next.7",
		"vite": "^7.2.6",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"@capacitor/android": "^8.3.0",
		"@capacitor/core": "^8.1.0",
		"@capacitor/ios": "^8.3.0",
		"@capacitor/local-notifications": "^8.0.2",
		"@capacitor/preferences": "^8.0.1",
		"@capacitor/push-notifications": "^8.0.3",
		"@graphql-codegen/typescript-graphql-request": "^6.4.0",
		"@tanstack/svelte-query": "^6.0.18",
		"@tanstack/svelte-virtual": "^3.13.19",
		"@tauri-apps/api": "^2.10.1",
		"@tauri-apps/plugin-notification": "^2.2.1",
		"@tauri-apps/plugin-process": "^2.3.1",
		"@tauri-apps/plugin-updater": "^2.10.0",
		"date-fns": "^4.1.0",
		"fast-json-stable-stringify": "^2.1.0",
		"graphql": "^16.12.0",
		"graphql-request": "^6.1.0",
		"graphql-ws": "^6.0.7",
		"pdfjs-dist": "^5.4.530",
		"zod": "^4.3.6"
	}
}
