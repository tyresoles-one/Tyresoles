{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Tyresoles",
  "version": "0.4.0",
  "identifier": "com.tyresoles.app",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Tyresoles",
        "width": 800,
        "height": 600,
        "resizable": true,
        "maximized": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../static/configs"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU4ODkwODQ2NkZERTQxRjgKUldUNFFkNXZSZ2lKV0l0eHJoRDhNOGovbzJOMHYwSFNaMjZTM2ZwR3FOSHdPeHdKZTdpODl2MUkK",
      "endpoints": [
        "http://app.tyresoles.net/updates/update.json"
      ],
      "dangerousInsecureTransportProtocol": true,
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
