<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2010/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=WIN-2A25CK9Q4FQ\TYRESOLES;Initial Catalog=Db_Mar16</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:DataSourceID>582f2579-23ca-4884-b0df-6fa61b7cb4d2</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet_Result">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select Ledger.[External Document No_] as 'ExternalDocumentNo_CustLedgerEntry', Ledger.[Customer No_] as 'CustomerNo_CustLedgerEntry','Tyresoles' as COMPANYNAME ,'PeriodText' as PeriodText, 'UserName' as UserName ,'SellToName' as SellToName, Ledger.[Posting Date] as 'PostingDate_CustLedgerEntry', Ledger.[Document Type] as 'DocumentType_CustLedgerEntry', Ledger.[Document No_] as 'DocumentNo_CustLedgerEntry', OBLedger.Amount as 'OpnBalance', DetailLedger.Amount as 'Amount_CustLedgerEntry', DetailLedger.DebitAmount as 'DebitAmount_CustLedgerEntry', DetailLedger.CreditAmount as 'CreditAmount_CustLedgerEntry', Ledger.[Source Code] as 'SourceCode_CustLedgerEntry', Areas.Name as 'AreaName', Ledger.Description, Customer.Name as 'CustomerName', Invoice.[Sell-to Customer Name] as 'InvName', CreditMemo.[Sell-to Customer Name] as 'CrdName', Dealer.Name as 'DealerName', States.Description as 'StateName', Customer.[Responsibility Center] as 'RespCenter'  from [dbo].[Tyresoles (India) Pvt_ Ltd_$Customer] as Customer left join (select * from [dbo].[Tyresoles (India) Pvt_ Ltd_$Cust_ Ledger Entry] as cle where cle.[Posting Date] between '01-Dec-2017' and '18-Dec-2017') as Ledger on Ledger.[Customer No_]=Customer.No_ left join (select sum(dle.Amount)as Amount, sum(dle.[Debit Amount])as 'DebitAmount', sum(dle.[Credit Amount]) as 'CreditAmount', dle.[Cust_ Ledger Entry No_] from [dbo].[Tyresoles (India) Pvt_ Ltd_$Detailed Cust_ Ledg_ Entry] as dle where dle.[Entry Type] in(0,1) group by dle.[Cust_ Ledger Entry No_]) as DetailLedger on DetailLedger.[Cust_ Ledger Entry No_] = Ledger.[Entry No_] left join (select sum(dle.Amount)as Amount,dle.[Customer No_] from [dbo].[Tyresoles (India) Pvt_ Ltd_$Detailed Cust_ Ledg_ Entry] as dle where dle.[Posting Date] &lt; '01-Dec-2017' group by dle.[Customer No_]) as OBLedger on OBLedger.[Customer No_] = Customer.No_ left join (select * from [dbo].[Tyresoles (India) Pvt_ Ltd_$Area] )as Areas on Areas.Code=Customer.[Area Code] left join (select * from [dbo].[Tyresoles (India) Pvt_ Ltd_$Sales Invoice Header]) as Invoice on Invoice.No_=Ledger.[Document No_] left join (select * from [dbo].[Tyresoles (India) Pvt_ Ltd_$Sales Cr_Memo Header])as CreditMemo on CreditMemo.No_ = Ledger.[Document No_]  left join (select * from [dbo].[Tyresoles (India) Pvt_ Ltd_$Salesperson_Purchaser]) as Dealer on Dealer.Code=Customer.[Dealer Code]  left join (select * from [dbo].[State]) as States on States.Code = Customer.[State Code]  left join (select * from [dbo].[Tyresoles (India) Pvt_ Ltd_$Team])as Teams on Teams.Code = Customer.[Area Code] left join (select * from [dbo].[Tyresoles (India) Pvt_ Ltd_$Team Salesperson]) as TeamMembers on TeamMembers.[Team Code]=Teams.Code  where Customer.[No_] in ('BCUS00000004','BCUS00000005','BCUS00000007','BCUS00000008','BCUS00000009','BCUS00000026','BCUS00000027','BCUS00000029','BCUS00004266','BCUS00010320','BCUS00011581','BCUS00011765','BCUS00012205','BCUS00012220','BCUS00012221','BCUS00012222','BCUS00012223','BCUS00012224','BCUS00000006','BCUS00000010','BCUS00000012','BCUS00000016','BCUS00000019','BCUS00000023','BCUS00000025','BCUS00005536','BCUS00010321','BCUS00011130','BCUS00011294','BCUS00011748','BCUS00011798','BCUS00012121') and  (Ledger.[Document Type] in (0,1,2,3,4,5,6))  order by Customer.No_, Ledger.[Posting Date]</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
