  <Code>Public Function BlankZero(ByVal Value As Decimal)
    if Value = 0 then
        Return ""
    end if
    Return Value
End Function

Public Function BlankPos(ByVal Value As Decimal)
    if Value &gt; 0 then
        Return ""
    end if
    Return Value
End Function

Public Function BlankZeroAndPos(ByVal Value As Decimal)
    if Value &gt;= 0 then
        Return ""
    end if
    Return Value
End Function

Public Function BlankNeg(ByVal Value As Decimal)
    if Value &lt; 0 then
        Return ""
    end if
    Return Value
End Function

Public Function BlankNegAndZero(ByVal Value As Decimal)
    if Value &lt;= 0 then
        Return ""
    end if
    Return Value
End Function
Shared Data1 as Object
Shared Data2 as Object
Public Function SetData(NewData as Object)
  If NewData &lt;&gt; "" Then
      Data1 = NewData
  End If
  Return True
End Function

Public Function GetData(Num as Integer) as Object
   Return Cstr(Choose(Num, Split(Cstr(Data1),Chr(177))))
End Function

Public Function SetData2(NewData as Object)
      Data2 = NewData
  Return True
End Function

Public Function GetData2(Num as Integer) as Object
   Return Data2
End Function

