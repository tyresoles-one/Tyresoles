  <Code>Public Function BlankZero(ByVal Value As Decimal)
    if Value = 0 then
        Return ""
    end if
    Return Value
End Function

Public Function BlankPos(ByVal Value As Decimal)
    if Value &gt; 0 then
        Return ""
    end if
    Return Value
End Function

Public Function BlankZeroAndPos(ByVal Value As Decimal)
    if Value &gt;= 0 then
        Return ""
    end if
    Return Value
End Function

Public Function BlankNeg(ByVal Value As Decimal)
    if Value &lt; 0 then
        Return ""
    end if
    Return Value
End Function

Public Function BlankNegAndZero(ByVal Value As Decimal)
    if Value &lt;= 0 then
        Return ""
    end if
    Return Value
End Function

Public Shared CustomerInfo as Object
Public Function SetData(NewData as Object) as Boolean
    If NewData&lt;&gt;"" Then
        CustomerInfo = NewData
        Return True	
    End If
End Function

Public Function GetData(Num as Integer) as Object
   Return Cstr(Choose(Num, Split(Cstr(CustomerInfo),Chr(177))))
End Function

Public Function PageNum() As Integer
  Return CInt(Me.Report.Globals!PageNumber)	
End Function

Public Function TotalPageNum() As Integer
  Return CInt(Me.Report.Globals!TotalPages)	
End Function</Code>
