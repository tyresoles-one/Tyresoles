                    [EmailEnabled] bit NOT NULL,
                    [PushEnabled] bit NOT NULL,
                    [UpdatedAt] datetime2 NOT NULL,
                    CONSTRAINT [PK_NotificationPreferences] PRIMARY KEY ([UserId], [Channel])
                );
            END

