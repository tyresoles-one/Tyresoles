                );
                CREATE INDEX [IX_Notifications_IsRead] ON dbo.[Notifications] ([IsRead]);
                CREATE INDEX [IX_Notifications_UserId_CreatedAt] ON dbo.[Notifications] ([UserId], [CreatedAt]);
            END

